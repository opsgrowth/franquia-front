# Copie para .env e preencha. NUNCA commite o .env real (está no .gitignore).
# São 3 vars, INLINADAS no build pelo Vite (import.meta.env.VITE_*) — precisam existir no
# momento do build. Em produção/staging elas vêm das Environment Variables da Vercel
# (por ambiente), não deste arquivo.

# URL do backend FastAPI do ambiente (Railway). Vazio → chamadas viram caminho relativo.
VITE_API_URL=https://SEU-BACKEND.up.railway.app

# Projeto Supabase do ambiente (AUTH apenas — login/sessão). Sem estes, o login é desligado.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_ANON_KEY_PUBLICA
